@model Microblog.Core.SystemMikroblogowania

@{
    ViewData["Title"] = "Users";
}



@if (Model.LiczbaUzytkownikow == 0)
{
    <div class="alert alert-info">
        No users yet.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Users</h1>
        <p class="text-muted mb-0">Registered users in the system</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">Register new user</a>
</div>

    <div class="row g-3">
        @for (int i = 0; i < Model.LiczbaUzytkownikow; i++)
        {
            var user = Model.Uzytkownicy[i];

            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <h5>
                            <a asp-action="Details" asp-route-id="@user.Id">
                                @user.NazwaUzytkownika
                            </a>
                        </h5>
                        <p class="text-muted mb-2">@user.Email</p>

                        <div class="small text-muted mb-2">
                            Registered: @user.DataRejestracji
                        </div>

                        <span class="badge bg-secondary">
                            Followers: @user.LiczbaObserwujacych
                        </span>
                        <form asp-action="Follow" method="post" class="mt-3">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Follow</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}